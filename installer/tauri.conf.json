{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "xConsole Setup",
  "version": "0.1.0",
  "identifier": "com.xconsole.installer",
  "build": {
    "frontendDist": "dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "xConsole Setup",
        "width": 760,
        "height": 580,
        "resizable": false,
        "center": true,
        "decorations": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "publisher": "xConsole",
    "copyright": "Copyright © 2026 xConsole. Licensed under MIT.",
    "category": "DeveloperTool",
    "shortDescription": "xConsole Setup",
    "longDescription": "Official setup for xConsole — a multi-VPS canvas terminal with a built-in AI agent. Downloads the open-source toolchain and compiles xConsole from source on this PC.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
